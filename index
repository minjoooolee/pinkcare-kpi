<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>핑크케어 KPI 대시보드</title>
<link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital@0;1&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --blue-accent: #4A7FA5;
    --blue-mid:    #7AAFC8;
    --blue-soft:   #B8D8E8;
    --blue-pale:   #E8F2F8;
    --bg:          #F4F6F8;
    --charcoal:    #1C2128;
    --gray-text:   #5A6470;
    --gray-light:  #C8D0D8;
    --line:        #E0E6EC;
    --white:       #FFFFFF;
    --green:       #2A9D6E;
    --amber:       #C07A2A;
    --red:         #B03A3A;
    --radius:      12px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Inter', sans-serif;
    background: var(--bg);
    color: var(--charcoal);
    min-height: 100vh;
    padding: 48px 24px 80px;
  }

  /* ── HEADER ── */
  .header {
    max-width: 960px;
    margin: 0 auto 52px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--line);
  }
  .logo-row { display: flex; align-items: center; gap: 14px; }
  .logo-dot {
    width: 8px; height: 32px;
    border-radius: 4px;
    background: var(--blue-accent);
    flex-shrink: 0;
  }
  .brand {
    font-family: 'Libre Baskerville', serif;
    font-size: 22px;
    color: var(--charcoal);
    letter-spacing: -0.3px;
    font-weight: 400;
  }
  .brand span { color: var(--blue-accent); }
  .period-badge {
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 6px 16px;
    font-size: 12px;
    font-weight: 500;
    color: var(--gray-text);
    white-space: nowrap;
    letter-spacing: .2px;
  }
  .period-badge span { color: var(--blue-accent); font-weight: 600; }

  /* ── SECTION LABEL ── */
  .section-header {
    max-width: 960px;
    margin: 0 auto 20px;
    display: flex;
    align-items: center;
    gap: 0;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: 10px;
    overflow: hidden;
  }
  .section-tag {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    padding: 14px 20px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .section-tag.primary  { background: var(--blue-accent); color: #fff; }
  .section-tag.secondary { background: var(--charcoal); color: #fff; }
  .section-divider {
    width: 1px;
    align-self: stretch;
    background: var(--line);
    flex-shrink: 0;
  }
  .section-question {
    padding: 12px 24px;
    flex: 1;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-question-text {
    font-family: 'Libre Baskerville', serif;
    font-size: 16px;
    font-weight: 400;
    color: var(--charcoal);
    line-height: 1.3;
  }
  .section-question-text em {
    font-style: normal;
    color: var(--blue-accent);
    font-weight: 700;
  }
  .section-question-mark {
    width: 24px; height: 24px;
    border-radius: 50%;
    background: var(--blue-pale);
    color: var(--blue-accent);
    font-size: 13px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .section-tag.secondary ~ .section-divider { background: #3a3f48; }
  .section-header.secondary-header .section-question-text em { color: var(--charcoal); }
  .section-header.secondary-header .section-question-mark {
    background: #EDEEF0;
    color: var(--charcoal);
  }

  /* ── GRID ── */
  .grid {
    max-width: 960px;
    margin: 0 auto 48px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 14px;
  }

  /* ── CARD ── */
  .card {
    background: var(--white);
    border-radius: var(--radius);
    border: 1px solid var(--line);
    padding: 24px 24px 20px;
    position: relative;
    overflow: hidden;
    transition: transform .18s, box-shadow .18s;
    cursor: pointer;
  }
  .card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(74,127,165,.10);
  }
  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    border-radius: var(--radius) var(--radius) 0 0;
    background: var(--blue-accent);
    opacity: 0;
    transition: opacity .18s;
  }
  .card:hover::before { opacity: 1; }

  /* Wide card (span 2) */
  .card.wide { grid-column: span 2; }
  @media (max-width: 600px) { .card.wide { grid-column: span 1; } }

  .card-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--blue-mid);
    margin-bottom: 5px;
  }
  .card-title {
    font-size: 14px;
    font-weight: 500;
    color: var(--charcoal);
    margin-bottom: 4px;
    line-height: 1.4;
  }
  .card-note {
    font-size: 11.5px;
    color: var(--gray-text);
    line-height: 1.55;
    margin-bottom: 20px;
  }

  /* ── METRIC ROW ── */
  .metric-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 10px;
  }
  .metric-current {
    font-family: 'Libre Baskerville', serif;
    font-size: 38px;
    line-height: 1;
    color: var(--charcoal);
    font-weight: 400;
  }
  .metric-target {
    font-size: 12px;
    color: var(--gray-text);
    padding-bottom: 4px;
    white-space: nowrap;
  }
  .metric-target b { color: var(--charcoal); font-weight: 600; }

  /* ── PROGRESS BAR ── */
  .progress-track {
    height: 4px;
    background: var(--line);
    border-radius: 999px;
    overflow: hidden;
    margin-bottom: 10px;
  }
  .progress-fill {
    height: 100%;
    border-radius: 999px;
    background: var(--blue-accent);
    transition: width 1s cubic-bezier(.4,0,.2,1);
  }

  /* ── STATUS BADGE ── */
  .status-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 12px;
    color: var(--gray-text);
  }
  .status-pill {
    font-size: 10px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 4px;
    letter-spacing: .5px;
    text-transform: uppercase;
  }
  .status-pill.on-track  { background: #E6F4EE; color: var(--green); }
  .status-pill.at-risk   { background: #FBF1E3; color: var(--amber); }
  .status-pill.critical  { background: #FBEBEB; color: var(--red); }
  .status-pill.achieved  { background: #E6F4EE; color: var(--green); }

  /* ── SUB-METRICS ── */
  .sub-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--line);
  }
  .sub-card {
    background: var(--bg);
    border-radius: 8px;
    padding: 12px 14px;
    border: 1px solid var(--line);
    cursor: pointer;
    transition: border-color .15s;
  }
  .sub-card:hover { border-color: var(--blue-mid); }
  .sub-label {
    font-size: 10px;
    font-weight: 600;
    color: var(--blue-accent);
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 2px;
  }
  .sub-name {
    font-size: 11px;
    color: var(--gray-text);
    margin-bottom: 8px;
    line-height: 1.4;
  }
  .sub-metric-row {
    display: flex;
    align-items: baseline;
    gap: 5px;
  }
  .sub-current {
    font-family: 'Libre Baskerville', serif;
    font-size: 22px;
    color: var(--charcoal);
  }
  .sub-target { font-size: 11px; color: var(--gray-text); }

  /* ── DIVIDER ── */
  .divider {
    max-width: 960px;
    margin: 0 auto 40px;
    border: none;
    border-top: 1px solid var(--line);
  }

  /* ── EDIT MODAL ── */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(28,33,40,.38);
    z-index: 100;
    align-items: center;
    justify-content: center;
  }
  .modal-overlay.open { display: flex; }
  .modal {
    background: var(--white);
    border-radius: 14px;
    padding: 32px;
    width: 100%;
    max-width: 400px;
    box-shadow: 0 20px 56px rgba(28,33,40,.14);
    animation: slideUp .22s cubic-bezier(.4,0,.2,1);
  }
  @keyframes slideUp {
    from { opacity:0; transform:translateY(16px); }
    to   { opacity:1; transform:translateY(0); }
  }
  .modal-title {
    font-family: 'Libre Baskerville', serif;
    font-size: 18px;
    color: var(--charcoal);
    margin-bottom: 4px;
    font-weight: 400;
  }
  .modal-sub {
    font-size: 12px;
    color: var(--gray-text);
    margin-bottom: 24px;
  }
  .field { margin-bottom: 18px; }
  .field label {
    display: block;
    font-size: 11px;
    font-weight: 600;
    color: var(--gray-text);
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .field input {
    width: 100%;
    padding: 10px 14px;
    border: 1.5px solid var(--line);
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    color: var(--charcoal);
    background: var(--bg);
    outline: none;
    transition: border-color .15s;
  }
  .field input:focus { border-color: var(--blue-accent); }
  .modal-actions {
    display: flex;
    gap: 10px;
    margin-top: 8px;
  }
  .btn {
    flex: 1;
    padding: 10px;
    border: none;
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity .15s;
  }
  .btn:hover { opacity: .82; }
  .btn-primary { background: var(--blue-accent); color: #fff; }
  .btn-ghost { background: var(--line); color: var(--gray-text); }

  /* ── FOOTER ── */
  .footer {
    max-width: 960px;
    margin: 0 auto;
    text-align: right;
    font-size: 11px;
    color: var(--gray-light);
    letter-spacing: .2px;
  }

  /* click hint */
  .click-hint {
    position: absolute;
    top: 14px; right: 16px;
    font-size: 10px;
    color: var(--line);
    font-weight: 500;
    letter-spacing: .4px;
    text-transform: uppercase;
    transition: color .18s;
  }
  .card:hover .click-hint { color: var(--blue-soft); }
</style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <div class="logo-row">
    <div class="logo-dot"></div>
    <span class="brand">핑크케어 <span>KPI</span></span>
  </div>
  <div class="period-badge">기준: <span>30일</span> · PoC 단계</div>
  <div id="header-actions" style="display:flex; gap:8px; align-items:center;"></div>

</div>

<!-- ══ PRIMARY KPI ══ -->
<div class="section-header">
  <span class="section-tag primary">Primary KPI</span>
  <div class="section-divider"></div>
  <div class="section-question">
    <div class="section-question-mark">?</div>
    <span class="section-question-text"><em>커뮤니티가 형성될만 한가?</em></span>
  </div>
</div>

<div class="grid" id="primary-grid">

  <!-- 1. 핑크케어 유입 -->
  <div class="card" data-id="inflow_p" onclick="openModal('inflow_p')">
    <span class="click-hint">수정 ✦</span>
    <div class="card-label">유입</div>
    <div class="card-title">핑크케어 유입</div>
    <div class="card-note">SEO 마케팅 의도적 미실시 — 자연 유입 중심</div>
    <div class="metric-row">
      <div class="metric-current" id="val-inflow_p">0</div>
      <div class="metric-target">목표 <b>100명</b></div>
    </div>
    <div class="progress-track"><div class="progress-fill" id="bar-inflow_p" style="width:0%"></div></div>
    <div class="status-row">
      <span id="pct-inflow_p">0%</span>
      <span class="status-pill" id="pill-inflow_p">–</span>
    </div>
  </div>

  <!-- 2. 오픈채팅 참여자 -->
  <div class="card" data-id="chat_join" onclick="openModal('chat_join')">
    <span class="click-hint">수정 ✦</span>
    <div class="card-label">참여</div>
    <div class="card-title">오픈채팅 참여자 수</div>
    <div class="card-note">액티브 사용자 기준 5배 규모 목표</div>
    <div class="metric-row">
      <div class="metric-current" id="val-chat_join">0</div>
      <div class="metric-target">목표 <b>20명</b></div>
    </div>
    <div class="progress-track"><div class="progress-fill" id="bar-chat_join" style="width:0%"></div></div>
    <div class="status-row">
      <span id="pct-chat_join">0%</span>
      <span class="status-pill" id="pill-chat_join">–</span>
    </div>
  </div>

  <!-- 3. 오픈채팅 메시지 -->
  <div class="card" data-id="messages" onclick="openModal('messages')">
    <span class="click-hint">수정 ✦</span>
    <div class="card-label">대화</div>
    <div class="card-title">오픈채팅 메시지 수</div>
    <div class="card-note">질문–경험 공유–답변 루프 형성 최소 규모</div>
    <div class="metric-row">
      <div class="metric-current" id="val-messages">0</div>
      <div class="metric-target">목표 <b>50건</b></div>
    </div>
    <div class="progress-track"><div class="progress-fill" id="bar-messages" style="width:0%"></div></div>
    <div class="status-row">
      <span id="pct-messages">0%</span>
      <span class="status-pill" id="pill-messages">–</span>
    </div>
  </div>

  <!-- 4. 액티브 사용자 (wide) -->
  <div class="card" data-id="active" onclick="openModal('active')">
    <span class="click-hint">수정 ✦</span>
    <div class="card-label">액티브</div>
    <div class="card-title">오픈채팅 액티브 사용자</div>
    <div class="card-note">초기 커뮤니티 대화 루프 형성: 3–5명 Active user 필요</div>
    <div class="metric-row">
      <div class="metric-current" id="val-active">0</div>
      <div class="metric-target">목표 <b>4명</b></div>
    </div>
    <div class="progress-track"><div class="progress-fill" id="bar-active" style="width:0%"></div></div>
    <div class="status-row">
      <span id="pct-active">0%</span>
      <span class="status-pill" id="pill-active">–</span>
    </div>
    <div class="sub-grid">
      <div class="sub-card" onclick="event.stopPropagation(); openModal('light_active')">
        <div class="sub-label">라이트</div>
        <div class="sub-name">30일 내 메시지 1건 이상</div>
        <div class="sub-metric-row">
          <div class="sub-current" id="val-light_active">0</div>
          <div class="sub-target">명</div>
        </div>
      </div>
      <div class="sub-card" onclick="event.stopPropagation(); openModal('core_active')">
        <div class="sub-label">코어</div>
        <div class="sub-name">메시지 5건+ 타인 글 반응 포함</div>
        <div class="sub-metric-row">
          <div class="sub-current" id="val-core_active">0</div>
          <div class="sub-target">명</div>
        </div>
      </div>
    </div>
  </div>

</div><!-- /primary grid -->

<hr class="divider">

<!-- ══ SECONDARY KPI ══ -->
<div class="section-header secondary-header">
  <span class="section-tag secondary">Secondary KPI</span>
  <div class="section-divider"></div>
  <div class="section-question">
    <div class="section-question-mark">?</div>
    <span class="section-question-text"><em>검사결과지 설명이 Hooking이 되는가?</em></span>
  </div>
</div>

<div class="grid" id="secondary-grid">

  <!-- 1. 핑크케어 유입 -->
  <div class="card" data-id="inflow_s" onclick="openModal('inflow_s')">
    <span class="click-hint">수정 ✦</span>
    <div class="card-label">유입</div>
    <div class="card-title">핑크케어 유입</div>
    <div class="card-note">Secondary KPI 기준 유입 수</div>
    <div class="metric-row">
      <div class="metric-current" id="val-inflow_s">0</div>
      <div class="metric-target">목표 <b>100명</b></div>
    </div>
    <div class="progress-track"><div class="progress-fill" id="bar-inflow_s" style="width:0%"></div></div>
    <div class="status-row">
      <span id="pct-inflow_s">0%</span>
      <span class="status-pill" id="pill-inflow_s">–</span>
    </div>
  </div>

  <!-- 2. 검사기록 업로드 -->
  <div class="card" data-id="upload" onclick="openModal('upload')">
    <span class="click-hint">수정 ✦</span>
    <div class="card-label">전환</div>
    <div class="card-title">검사기록 업로드</div>
    <div class="card-note">유입 대비 전환율 10% 목표</div>
    <div class="metric-row">
      <div class="metric-current" id="val-upload">0</div>
      <div class="metric-target">목표 <b>10명</b></div>
    </div>
    <div class="progress-track"><div class="progress-fill" id="bar-upload" style="width:0%"></div></div>
    <div class="status-row">
      <span id="pct-upload">0%</span>
      <span class="status-pill" id="pill-upload">–</span>
    </div>
  </div>

  <!-- 3. 오픈채팅 유입 -->
  <div class="card" data-id="chat_from_result" onclick="openModal('chat_from_result')">
    <span class="click-hint">수정 ✦</span>
    <div class="card-label">연결</div>
    <div class="card-title">오픈채팅 유입 (결과지 경유)</div>
    <div class="card-note">검사결과지 설명 → 커뮤니티 참여 검증</div>
    <div class="metric-row">
      <div class="metric-current" id="val-chat_from_result">0</div>
      <div class="metric-target">목표 <b>10명</b></div>
    </div>
    <div class="progress-track"><div class="progress-fill" id="bar-chat_from_result" style="width:0%"></div></div>
    <div class="status-row">
      <span id="pct-chat_from_result">0%</span>
      <span class="status-pill" id="pill-chat_from_result">–</span>
    </div>
  </div>

</div><!-- /secondary grid -->

<div class="footer" id="footer-time">마지막 업데이트: –</div>

<!-- ══ EDIT MODAL ══ -->
<div class="modal-overlay" id="modal-overlay" onclick="closeModal(event)">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-title" id="modal-title">수치 수정</div>
    <div class="modal-sub" id="modal-sub">현재 수치를 입력하세요</div>
    <div class="field">
      <label>현재 수치</label>
      <input type="number" id="modal-input" min="0" placeholder="0">
    </div>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeModalDirect()">취소</button>
      <button class="btn btn-primary" onclick="saveModal()">저장</button>
    </div>
  </div>
</div>

<!-- ══ SHARE TOAST ══ -->
<div id="share-toast" style="
  position:fixed; bottom:32px; left:50%; transform:translateX(-50%) translateY(20px);
  background:var(--charcoal); color:#fff; padding:10px 22px; border-radius:8px;
  font-size:13px; font-weight:500; opacity:0; transition:all .25s; pointer-events:none; z-index:200;
  white-space:nowrap;
">링크가 복사됐습니다 ✓</div>

<script>
// ── CONFIG ──────────────────────────────────────────────
const METRICS = {
  inflow_p:         { label: '핑크케어 유입 (Primary)', target: 100 },
  chat_join:        { label: '오픈채팅 참여자 수',       target: 20  },
  active:           { label: '오픈채팅 액티브 사용자',   target: 4   },
  light_active:     { label: '라이트 액티브',            target: null },
  core_active:      { label: '코어 액티브',              target: null },
  messages:         { label: '오픈채팅 메시지 수',       target: 50  },
  inflow_s:         { label: '핑크케어 유입 (Secondary)',target: 100 },
  upload:           { label: '검사기록 업로드',          target: 10  },
  chat_from_result: { label: '오픈채팅 유입 (결과지)',   target: 10  },
};

const EDIT_PASSWORD = 'pinkcare2025';

// ── MODE 판별 ─────────────────────────────────────────────
// ?view=1 파라미터가 있으면 뷰어 모드, 없으면 편집 모드
const params = new URLSearchParams(window.location.search);
const IS_VIEW_MODE = params.has('view');

// ── STATE ────────────────────────────────────────────────
let state = {};

function loadState() {
  Object.keys(METRICS).forEach(k => state[k] = 0);
  try {
    // 데이터는 항상 URL 해시에서 읽기
    const hash = window.location.hash.slice(1);
    if (hash) {
      hash.split('&').forEach(pair => {
        const [k, v] = pair.split('=');
        if (k && METRICS[k] !== undefined) state[k] = parseInt(v, 10) || 0;
      });
    }
  } catch(e) {}
}

function saveState() {
  const hash = Object.keys(state).map(k => `${k}=${state[k]}`).join('&');
  history.replaceState(null, '', (IS_VIEW_MODE ? '?view=1' : '') + '#' + hash);
  updateFooter();
}

function buildShareUrl() {
  const hash = Object.keys(state).map(k => `${k}=${state[k]}`).join('&');
  const base = window.location.href.split('?')[0].split('#')[0];
  return `${base}?view=1#${hash}`;
}

// ── UI 모드 적용 ──────────────────────────────────────────
function applyMode() {
  const actions = document.getElementById('header-actions');

  if (IS_VIEW_MODE) {
    // 뷰어 모드: 카드 클릭 불가, 수정 힌트 숨김, 뷰어 배지 표시
    document.querySelectorAll('.card').forEach(c => {
      c.style.cursor = 'default';
      c.onclick = null;
    });
    document.querySelectorAll('.sub-card').forEach(c => {
      c.style.cursor = 'default';
      c.onclick = null;
    });
    document.querySelectorAll('.click-hint').forEach(el => el.style.display = 'none');

    actions.innerHTML = `
      <span style="font-size:11px; color:var(--gray-text); font-weight:500; padding:7px 12px;
        background:var(--bg); border:1px solid var(--line); border-radius:6px;">
        👁 보기 전용
      </span>`;
  } else {
    // 편집 모드: 공유 링크 버튼 표시
    actions.innerHTML = `
      <button onclick="copyShareLink()" style="
        background:var(--blue-accent); color:#fff; border:none; border-radius:6px;
        padding:7px 16px; font-family:'Inter',sans-serif; font-size:12px; font-weight:600;
        cursor:pointer; display:flex; align-items:center; gap:6px; white-space:nowrap;">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
        보고용 링크 복사
      </button>`;
  }
}

// ── SHARE ─────────────────────────────────────────────────
function copyShareLink() {
  const url = buildShareUrl();
  navigator.clipboard.writeText(url).then(() => {
    const toast = document.getElementById('share-toast');
    toast.style.opacity = '1';
    toast.style.transform = 'translateX(-50%) translateY(0)';
    setTimeout(() => {
      toast.style.opacity = '0';
      toast.style.transform = 'translateX(-50%) translateY(20px)';
    }, 2400);
  });
}

// ── RENDER ───────────────────────────────────────────────
function getStatus(pct) {
  if (pct >= 100) return ['achieved', '달성 ✓'];
  if (pct >= 60)  return ['on-track', 'On Track'];
  if (pct >= 30)  return ['at-risk', 'At Risk'];
  return ['critical', 'Critical'];
}

function renderAll() {
  Object.keys(METRICS).forEach(id => {
    const m = METRICS[id];
    const val = state[id] || 0;
    const el = document.getElementById('val-' + id);
    if (el) el.textContent = val.toLocaleString();
    if (m.target !== null) {
      const pct = Math.min(Math.round(val / m.target * 100), 100);
      const barEl = document.getElementById('bar-' + id);
      const pctEl = document.getElementById('pct-' + id);
      const pillEl = document.getElementById('pill-' + id);
      if (barEl) barEl.style.width = pct + '%';
      if (pctEl) pctEl.textContent = pct + '%';
      if (pillEl) {
        const [cls, txt] = getStatus(pct);
        pillEl.className = 'status-pill ' + cls;
        pillEl.textContent = txt;
      }
    }
  });
}

function updateFooter() {
  const now = new Date();
  const fmt = now.toLocaleDateString('ko-KR', { year:'numeric', month:'long', day:'numeric' })
    + ' ' + now.toLocaleTimeString('ko-KR', { hour:'2-digit', minute:'2-digit' });
  document.getElementById('footer-time').textContent = '마지막 업데이트: ' + fmt;
}

// ── MODAL (편집 모드 전용) ────────────────────────────────
let currentId = null;

function openModal(id) {
  if (IS_VIEW_MODE) return;
  currentId = id;
  const m = METRICS[id];
  document.getElementById('modal-title').textContent = m.label;
  document.getElementById('modal-sub').textContent =
    m.target ? `목표: ${m.target.toLocaleString()}` : '현재 수치를 입력하세요';
  document.getElementById('modal-input').value = state[id] || 0;
  document.getElementById('modal-overlay').classList.add('open');
  setTimeout(() => document.getElementById('modal-input').focus(), 100);
}

function closeModal(e) {
  if (e.target === document.getElementById('modal-overlay')) closeModalDirect();
}
function closeModalDirect() {
  document.getElementById('modal-overlay').classList.remove('open');
  currentId = null;
}

function saveModal() {
  if (!currentId) return;
  const val = parseInt(document.getElementById('modal-input').value, 10);
  if (!isNaN(val) && val >= 0) {
    state[currentId] = val;
    saveState();
    renderAll();
  }
  closeModalDirect();
}

document.getElementById('modal-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') saveModal();
  if (e.key === 'Escape') closeModalDirect();
});

// ── INIT ─────────────────────────────────────────────────
loadState();
applyMode();
renderAll();
if (window.location.hash) updateFooter();
</script>
</body>
</html>
